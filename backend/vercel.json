{
  "version": 2,
  "buildCommand": "echo skip",
  "outputDirectory": ".",
  "functions": {
    "api/*.js": {
      "runtime": "nodejs22.x"
    }
  },
  "routes": [
    {
      "src": "/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/api/transcribe",
      "dest": "/api/transcribe.js"
    }
  ]
}
